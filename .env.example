# Green Compute miner config. Subnet is 'Green Compute' — technical
# prefix was renamed from GREENFERENCE_ to GREENCOMPUTE_ during the
# 2026-04 rebrand. The agent reads BOTH prefixes during the transition,
# so if you're upgrading from an older checkout you can leave your
# existing GREENFERENCE_* vars in place until you're ready to migrate.

# ── control plane (HTTP, on validator VPS) ──
GREENCOMPUTE_CONTROL_PLANE_URL=http://xx.xx.xx.xx:28001

# ── bittensor identity ──
GREENCOMPUTE_MINER_HOTKEY=5F6WRq6fB5bMT6dXHZxUXw35XNQKMHhGRz9vdV6QmMapZsb9
GREENCOMPUTE_MINER_PAYOUT_ADDRESS=5CUtRPJ52bZHhpyTKRak7rTh9ug9VQZZVjBfewYPH2zkQhWZ
GREENCOMPUTE_MINER_AUTH_SECRET=your-shared-secret
# GREENCOMPUTE_MINER_API_BASE_URL=http://xx.xx.xx.xx:8007
GREENCOMPUTE_MINER_VALIDATOR_URL=http://xx.xx.xx.xx:28002
# IMPORTANT: node_id is a primary key on the control-plane side, so every
# miner host needs a DIFFERENT value. Leave commented out to auto-derive a
# unique one from the hotkey, or set your own (e.g. "node-8x4090-alpha").
# GREENCOMPUTE_MINER_NODE_ID=node-8x4090-alpha

# ── hardware ──
GREENCOMPUTE_GPU_MODEL=rtx4090
GREENCOMPUTE_GPU_COUNT=8
GREENCOMPUTE_VRAM_GB_PER_GPU=24
GREENCOMPUTE_CPU_CORES=80
GREENCOMPUTE_MEMORY_GB=360
GREENCOMPUTE_PERFORMANCE_SCORE=1.0
GREENCOMPUTE_GPU_SPLIT_UNITS=100

# ── auth mode: "hotkey" (ed25519, production) or "hmac" (shared secret, dev) ──
GREENCOMPUTE_AUTH_MODE=hotkey
# Bittensor wallet names (reads from ~/.bittensor/wallets/{coldkey}/hotkeys/{hotkey})
GREENCOMPUTE_COLDKEY_NAME=coldkey_name
GREENCOMPUTE_HOTKEY_NAME=hotkey_name

# ── security ──
GREENCOMPUTE_SECURITY_TIER=standard
GREENCOMPUTE_ATTESTATION_ENABLED=false

# ── backends ──
GREENCOMPUTE_POD_BACKEND=process
GREENCOMPUTE_VM_BACKEND=stub
GREENCOMPUTE_INFERENCE_BACKEND=docker

# ── HuggingFace (for vLLM model downloads) ──
HF_TOKEN=
HF_HOME=/root/.cache/huggingface

# ── workload kinds ──
GREENCOMPUTE_SUPPORTED_WORKLOAD_KINDS=inference,pod,vm

# ── ssh (pod access) ──
GREENCOMPUTE_SSH_HOST=xx.xx.xx.xx
GREENCOMPUTE_SSH_PORT_RANGE_START=30000
GREENCOMPUTE_SSH_PORT_RANGE_END=31000

# ── persistence ──
GREENCOMPUTE_RUNTIME_STATE_PATH=/tmp/greencompute-node-runtime-state.json
GREENCOMPUTE_VOLUME_BASE_DIR=/tmp/greencompute-node-volumes

# ── agent loop ──
GREENCOMPUTE_BOOTSTRAP_MINER=true
GREENCOMPUTE_ENABLE_BACKGROUND_WORKERS=true
GREENCOMPUTE_WORKER_POLL_INTERVAL_SECONDS=1.0

# ── port range ──
# GREENCOMPUTE_SSH_PORT_RANGE_START=31000
# GREENCOMPUTE_SSH_PORT_RANGE_END=31100
