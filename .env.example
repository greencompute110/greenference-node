# ── control plane (HTTP, on validator VPS) ──
GREENFERENCE_CONTROL_PLANE_URL=http://xx.xx.xx.xx:28001

# ── bittensor identity ──
GREENFERENCE_MINER_HOTKEY=5F6WRq6fB5bMT6dXHZxUXw35XNQKMHhGRz9vdV6QmMapZsb9
GREENFERENCE_MINER_PAYOUT_ADDRESS=5CUtRPJ52bZHhpyTKRak7rTh9ug9VQZZVjBfewYPH2zkQhWZ
GREENFERENCE_MINER_AUTH_SECRET=your-shared-secret
# GREENFERENCE_MINER_API_BASE_URL=http://xx.xx.xx.xx:8007
GREENFERENCE_MINER_VALIDATOR_URL=http://xx.xx.xx.xx:28002
# IMPORTANT: node_id is a primary key on the control-plane side, so every
# miner host needs a DIFFERENT value. Leave commented out to auto-derive a
# unique one from the hotkey, or set your own (e.g. "node-8x4090-alpha").
# GREENFERENCE_MINER_NODE_ID=node-8x4090-alpha

# ── hardware ──
GREENFERENCE_GPU_MODEL=rtx4090
GREENFERENCE_GPU_COUNT=8
GREENFERENCE_VRAM_GB_PER_GPU=24
GREENFERENCE_CPU_CORES=80
GREENFERENCE_MEMORY_GB=360
GREENFERENCE_PERFORMANCE_SCORE=1.0
GREENFERENCE_GPU_SPLIT_UNITS=100

# ── auth mode: "hotkey" (ed25519, production) or "hmac" (shared secret, dev) ──
GREENFERENCE_AUTH_MODE=hotkey
# Bittensor wallet names (reads from ~/.bittensor/wallets/{coldkey}/hotkeys/{hotkey})
GREENFERENCE_COLDKEY_NAME=coldkey_name
GREENFERENCE_HOTKEY_NAME=hotkey_name

# ── security ──
GREENFERENCE_SECURITY_TIER=standard
GREENFERENCE_ATTESTATION_ENABLED=false

# ── backends ──
GREENFERENCE_POD_BACKEND=process
GREENFERENCE_VM_BACKEND=stub
GREENFERENCE_INFERENCE_BACKEND=docker

# ── HuggingFace (for vLLM model downloads) ──
HF_TOKEN=
HF_HOME=/root/.cache/huggingface

# ── workload kinds ──
GREENFERENCE_SUPPORTED_WORKLOAD_KINDS=inference,pod,vm

# ── ssh (pod access) ──
GREENFERENCE_SSH_HOST=xx.xx.xx.xx
GREENFERENCE_SSH_PORT_RANGE_START=30000
GREENFERENCE_SSH_PORT_RANGE_END=31000

# ── persistence ──
GREENFERENCE_RUNTIME_STATE_PATH=/tmp/greenference-node-runtime-state.json
GREENFERENCE_VOLUME_BASE_DIR=/tmp/greenference-node-volumes

# ── agent loop ──
GREENFERENCE_BOOTSTRAP_MINER=true
GREENFERENCE_ENABLE_BACKGROUND_WORKERS=true
GREENFERENCE_WORKER_POLL_INTERVAL_SECONDS=1.0

# ── port range ──
# GREENFERENCE_SSH_PORT_RANGE_START=31000
# GREENFERENCE_SSH_PORT_RANGE_END=31100
